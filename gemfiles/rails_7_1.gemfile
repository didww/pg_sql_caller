# frozen_string_literal: true

# Pins ActiveRecord/ActiveSupport to the Rails 7.1 series for the CI test matrix.
# Run with: BUNDLE_GEMFILE=gemfiles/rails_7_1.gemfile bundle exec rspec

source 'https://rubygems.org'

gemspec path: '..'

gem 'activerecord', '~> 7.1.0'
gem 'activesupport', '~> 7.1.0'

gem 'database_cleaner'
gem 'pg'

gem 'rspec', '~> 3.13'
